                    ||'.page-31 .scaff-section__head{background:linear-gradient(90deg,#2b2f38 0%,#3c424f 100%);color:#fff;text-align:center;padding:10px 14px;font-weight:700;letter-spacing:.02em;border-radius:12px;margin:8px 0;box-shadow:0 10px 24px rgba(28,34,51,.18)}'
                    ||'.page-31 .t-Form-fieldContainer{background:#fff;border:1px solid #e8ecf4;border-radius:12px;padding:8px 10px;margin:8px 0;box-shadow:0 6px 18px rgba(15,23,42,.05)}'
                    ||'.page-31 .t-Form-fieldContainer--floatingLabel .t-Form-label{font-weight:600;color:#6b7280;letter-spacing:.01em}'
                    ||'.page-31 .t-Form-inputContainer input,.page-31 .t-Form-inputContainer select,.page-31 .t-Form-inputContainer textarea{border:1px solid #d8dfeb !important;border-radius:10px !important;background:#fff !important}'
                    ||'.page-31 .t-Form-inputContainer textarea{min-height:108px}'
                    ||'.page-31 .t-Form-fieldContainer:focus-within{border-color:#b6c2d8;box-shadow:0 0 0 3px rgba(29,78,216,.08),0 10px 22px rgba(15,23,42,.08)}'
                    ||'.page-31 [data-otel-label="SAVE"]{border-radius:999px !important;padding:0 20px !important;box-shadow:0 10px 24px rgba(226,0,26,.26)}'
                    ||'.page-31 [data-otel-label="CANCEL"]{border-radius:999px !important;padding:0 18px !important}'
                    ||'</style>'
