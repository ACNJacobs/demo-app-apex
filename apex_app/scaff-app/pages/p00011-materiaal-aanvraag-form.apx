page 11 (
    name: Materiaal aanvraag - formulier
    alias: MATERIAAL-AANVRAAG-FORM
    title: Materiaal aanvraag
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    javaScript {
        executeWhenPageLoads:
            ```javascript-browser
            (function(){
              // Datepicker: minimum = today + 5 business days, no weekends.
              function addBizDays(d, n) {
                var x = new Date(d.getFullYear(), d.getMonth(), d.getDate());
                var left = n;
                while (left > 0) {
                  x.setDate(x.getDate() + 1);
                  var dow = x.getDay();
                  if (dow !== 0 && dow !== 6) { left--; }
                }
                return x;
              }
              function iso(d){
                return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0');
              }
              var dp = document.getElementById('P11_DATUM');
              if (dp) {
                var minD = addBizDays(new Date(), 5);
                try { dp.setAttribute('min-value', iso(minD)); } catch(e) {}
                try { dp.setAttribute('valid-example', iso(minD)); } catch(e) {}
                // Disable weekends via apex.date.dateValidationFn-like hook on a-date-picker
                dp.disabledDates = function(d){ var w = d.getDay(); return w === 0 || w === 6; };
              }
            
              // Success banner -> redirect after 2s.
              var s = document.querySelector('.t-Body-alert .t-Alert--success, #APEX_SUCCESS_MESSAGE .t-Alert--success');
              if (!s) { return; }
              var txt = (s.textContent || '').replace(/\s+/g,'');
              if (!txt) { return; }
              var reqId = (apex.item('P11_REQUEST_ID').getValue() || '').toString();
              var targetPage = reqId ? '50' : '10';
              setTimeout(function(){
                try { apex.message.hidePageSuccess(); } catch(e) {}
                apex.navigation.redirect( apex.util.makeApplicationUrl({ pageId: targetPage }) );
              }, 2000);
            })();

            // Translate form labels (messages registered server-side by region i18n-labels)
            (function(){
              if (window._scaffMsgData) { apex.lang.addMessages(window._scaffMsgData); }
              var labelMap = {
                'P11_CONTACT':    'SCAFF.MR.FORM.CONTACT',
                'P11_WERFLEIDER': 'SCAFF.MR.FORM.WERFLEIDER',
                'P11_GSM':        'SCAFF.MR.FORM.GSM',
                'P11_DATUM':      'SCAFF.MR.FORM.DELIVERY_DATE',
                'P11_VERVOER':    'SCAFF.MR.FORM.VERVOER',
                'P11_LADER':      'SCAFF.MR.FORM.LADER',
                'P11_UUR':        'SCAFF.MR.FORM.UUR',
                'P11_AANHOUDEN':  'SCAFF.MR.FORM.AANHOUDEN',
                'P11_OPMERKING':  'SCAFF.MR.FORM.OPMERKING'
              };
              Object.keys(labelMap).forEach(function(itemId) {
                var msg = apex.lang.getMessage(labelMap[itemId]);
                if (!msg || msg === labelMap[itemId]) { return; }
                var lbl = document.querySelector('label[for="' + itemId + '"]');
                if (lbl) {
                  var tn = lbl.childNodes[0];
                  if (tn && tn.nodeType === 3) { tn.textContent = msg; }
                  else { lbl.prepend(document.createTextNode(msg)); }
                }
              });
              var msgSave = apex.lang.getMessage('SCAFF.MR.FORM.BTN.SAVE');
              var msgCancel = apex.lang.getMessage('SCAFF.MR.FORM.BTN.CANCEL');
              if (msgSave && msgSave !== 'SCAFF.MR.FORM.BTN.SAVE') {
                document.querySelectorAll('button.t-Button--hot').forEach(function(b){
                  if (/Opslaan/i.test(b.textContent.trim())) { b.textContent = msgSave; }
                });
              }
              if (msgCancel && msgCancel !== 'SCAFF.MR.FORM.BTN.CANCEL') {
                document.querySelectorAll('button.t-Button:not(.t-Button--hot)').forEach(function(b){
                  if (/Annuleren/i.test(b.textContent.trim())) { b.textContent = msgCancel; }
                });
              }
            })();
            ```
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region i18n-labels (
        name: i18n labels
        type: dynamicContent
        source {
            plsqlFunctionBody:
                ```plsql
                declare
                  function msg(p_key varchar2) return varchar2 is
                    l_m varchar2(4000) := apex_lang.message(p_key);
                  begin
                    return '"'||replace(replace(p_key,'\','\\'),'"','\"')||'":"'
                               ||replace(replace(l_m,'\','\\'),'"','\"')||'"';
                  end;
                begin
                  return '<script>window._scaffMsgData={'||
                    msg('SCAFF.MR.FORM.CONTACT')||','||
                    msg('SCAFF.MR.FORM.WERFLEIDER')||','||
                    msg('SCAFF.MR.FORM.GSM')||','||
                    msg('SCAFF.MR.FORM.DELIVERY_DATE')||','||
                    msg('SCAFF.MR.FORM.VERVOER')||','||
                    msg('SCAFF.MR.FORM.LADER')||','||
                    msg('SCAFF.MR.FORM.UUR')||','||
                    msg('SCAFF.MR.FORM.AANHOUDEN')||','||
                    msg('SCAFF.MR.FORM.OPMERKING')||','||
                    msg('SCAFF.MR.FORM.BTN.SAVE')||','||
                    msg('SCAFF.MR.FORM.BTN.CANCEL')||
                  '};</scr'||'ipt>';
                end;
                ```
        }
        layout {
            sequence: 1
            slot: body
        }
        appearance {
            template: @/blank-with-attributes-no-grid
            templateOptions: #DEFAULT#
        }
    )

