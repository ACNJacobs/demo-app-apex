page 11 (
    name: Materiaal aanvraag - formulier
    alias: MATERIAAL-AANVRAAG-FORM
    title: Materiaal aanvraag
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    javaScript {
        executeWhenPageLoads:
            ```javascript-browser
            (function(){
              var s = document.querySelector('.t-Body-alert .t-Alert--success, #APEX_SUCCESS_MESSAGE .t-Alert--success');
              if (!s) { return; }
              var txt = (s.textContent || '').replace(/\s+/g,'');
              if (!txt) { return; }
              var reqId = (apex.item('P11_REQUEST_ID').getValue() || '').toString();
              var targetPage = reqId ? '50' : '10';
              setTimeout(function(){
                try { apex.message.hidePageSuccess(); } catch(e) {}
                apex.navigation.redirect( apex.util.makeApplicationUrl({ pageId: targetPage }) );
              }, 2000);
            })();
            ```
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

