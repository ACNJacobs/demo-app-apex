    region scaff-mr-header (
        name: PO header
        type: dynamicContent
        source {
            plsqlFunctionBody:
                ```plsql
                return '<style id="scaff-mobile-css">'||HD_MOBILE_UI_PKG.get_menu_css||'</style>'
                    ||'<div class="scaff-section__head">'||apex_escape.html(apex_lang.message('SCAFF.MR.LIST.HEAD'))||'</div>'
                    ||'<div class="scaff-section__sub"><strong>'||apex_escape.html(nvl(:P11_PO_DISPLAY,'?'))||'</strong>'||apex_escape.html(:P11_CUSTOMER)||'</div>';
                ```
            pageItemsToSubmit: [
                P11_PO_DISPLAY
                P11_CUSTOMER
            ]
        }
        layout {
            sequence: 5
            slot: body
        }
        appearance {
            template: @/blank-with-attributes-no-grid
            templateOptions: #DEFAULT#
        }
