page 21 (
    name: Retour aanvraag - formulier
    alias: RETOUR-AANVRAAG-FORM
    title: Retour aanvraag
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    javaScript {
        executeWhenPageLoads:
            ```javascript-browser
            (function(){
              // Load label translations
              apex.server.process('GET_LABEL_TRANSLATIONS', {}, {
                success: function(data) {
                  // Update form labels
                  Object.keys(data).forEach(function(key) {
                    var label = data[key];
                    // Update item labels
                    if (key.startsWith('P_LBL_')) {
                      var itemId = key.replace('P_LBL_', 'P21_');
                      var item = apex.item(itemId);
                      if (item) {
                        // For items with labels, update the label
                        var labelElem = $('label[for="' + item.id + '"]');
                        if (labelElem.length) {
                          labelElem.text(label);
                        }
                      }
                    }
                  });
                  
                  // Update static labels (prefix, search, etc.)
                  $('[data-i18n]').each(function() {
                    var key = $(this).data('i18n');
                    if (data[key]) {
                      $(this).text(data[key]);
                    }
                  });
                }
              });

              // Datepicker: minimum = today + 5 business days, no weekends.
              function addBizDays(d, n) {
                var x = new Date(d.getFullYear(), d.getMonth(), d.getDate());
                var left = n;
                while (left > 0) {
                  x.setDate(x.getDate() + 1);
                  var dow = x.getDay();
                  if (dow !== 0 && dow !== 6) { left--; }
                }
                return x;
              }
              function iso(d){
                return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0');
              }
              var dp = document.getElementById('P21_DATUM');
              if (dp) {
                var minD = addBizDays(new Date(), 5);
                try { dp.setAttribute('min-value', iso(minD)); } catch(e) {}
                try { dp.setAttribute('valid-example', iso(minD)); } catch(e) {}
                dp.disabledDates = function(d){ var w = d.getDay(); return w === 0 || w === 6; };
              }
            
              // Hide Vervoer/Lader when "Transport reeds uitgevoerd" = Y
              function syncTransport(){
                var v = apex.item('P21_TRANSPORT_DONE').getValue();
                var done = (v === 'Y' || v === '1' || v === true);
                ['P21_VERVOER','P21_LADER'].forEach(function(it){
                  var w = document.querySelector('#'+it+'_CONTAINER, .t-Form-fieldContainer[data-for="'+it+'"]');
                  if (w) { w.style.display = done ? 'none' : ''; }
                  // also disable on min datum constraint when transport already done
                });
                // Min datum: skip 5-BD rule when transport already done
                if (dp) {
                  if (done) { try { dp.removeAttribute('min-value'); } catch(e) {} dp.disabledDates = null; }
                  else {
                    var minD2 = addBizDays(new Date(), 5);
                    try { dp.setAttribute('min-value', iso(minD2)); } catch(e) {}
                    dp.disabledDates = function(d){ var w = d.getDay(); return w === 0 || w === 6; };
                  }
                }
              }
              try { syncTransport(); } catch(e) {}
              apex.item('P21_TRANSPORT_DONE').element.on && apex.item('P21_TRANSPORT_DONE').element.on('change', syncTransport);
              document.getElementById('P21_TRANSPORT_DONE') && document.getElementById('P21_TRANSPORT_DONE').addEventListener('change', syncTransport);
            
              // Success banner -> redirect after 2s.
              var s = document.querySelector('.t-Body-alert .t-Alert--success, #APEX_SUCCESS_MESSAGE .t-Alert--success');
              if (!s) { return; }
              var txt = (s.textContent || '').replace(/\s+/g,'');
              if (!txt) { return; }
              var reqId = (apex.item('P21_RETURN_ID').getValue() || '').toString();
              var targetPage = reqId ? '50' : '20';
              setTimeout(function(){
                try { apex.message.hidePageSuccess(); } catch(e) {}
                apex.navigation.redirect( apex.util.makeApplicationUrl({ pageId: targetPage }) );
              }, 2000);
            })();
            ```
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

