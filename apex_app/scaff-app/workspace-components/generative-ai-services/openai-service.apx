genAIService openai-service (
    name: OpenAI Service
    provider: OLLAMA
    endpointUrl {
        url: http://host.docker.internal:11434
    }
    authentication {
        credentials: @credentials-for-openai-service
    }
    appBuilder {
        usedByAppBuilder: true
        defaultForNewApps: true
    }
    advanced {
        modelName: gpt-oss:20b-cloud
    }
)

